{
  "scripts": {
    "optimize:images": "node scripts/optimize-images.js",
    "minify:js": "terser ./js/script.js -o ./js/script.min.js",
    "minify:css": "cleancss -o ./css/style.min.css ./css/style.css",
    "build": "npm run optimize:images && npm run minify:css && npm run minify:js"
  },
  "devDependencies": {
    "clean-css-cli": "^5.6.3",
    "sharp": "^0.33.2",
    "terser": "^5.42.0"
  }
}
